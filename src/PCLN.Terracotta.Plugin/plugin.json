{
  "formatVersion": 1,
  "manifestVersion": 1,
  "id": "cn.pcln.terracotta",
  "name": "陶瓦联机",
  "version": "0.1.3",
  "channel": "stable",
  "summary": "PCL N 官方 Minecraft P2P 联机插件。",
  "description": "通过陶瓦联机 Helper、EasyTier 与 Scaffolding 提供跨启动器的 Minecraft P2P 联机能力。",
  "publisher": {
    "id": "github:MuXue1230-owo",
    "namespace": "cn.pcln"
  },
  "license": "Apache-2.0",
  "entryPoint": {
    "assembly": "lib/net10.0/PCLN.Terracotta.Plugin.dll",
    "type": "Cn.Pcln.Terracotta.PluginEntry"
  },
  "api": {
    "minimum": "0.1",
    "maximumExclusive": "1.0"
  },
  "host": {
    "minimumVersion": "1.0.0"
  },
  "data": {
    "schemaVersion": 1,
    "minimumReadableSchema": 1
  },
  "services": {
    "required": {
      "pcl.logging": ">=0.1 <1.0",
      "pcl.settings": ">=0.1 <1.0",
      "pcl.commands": ">=0.1 <1.0",
      "pcl.tasks": ">=0.1 <1.0",
      "pcl.instances.read": ">=0.1 <1.0",
      "pcl.game.sessions": ">=0.1 <1.0",
      "pcl.launch.events": ">=0.1 <1.0",
      "pcl.process": ">=0.1 <1.0",
      "pcl.ui.avalonia.pages": ">=0.1 <1.0",
      "pcl.localization": ">=0.1 <1.0"
    },
    "optional": {
      "pcl.ui.avalonia.windows": ">=0.1 <1.0",
      "pcl.ui.components": ">=0.1 <1.0",
      "pcl.background-tasks": ">=0.1 <1.0",
      "pcl.game.output": ">=0.1 <1.0",
      "pcl.clipboard": ">=0.1 <1.0",
      "pcl.secure-storage": ">=0.1 <1.0",
      "pcl.notifications": ">=0.1 <1.0",
      "pcl.uri-launcher": ">=0.1 <1.0",
      "pcl.package-assets": ">=0.1 <1.0",
      "pcl.exports": ">=0.1 <1.0"
    }
  },
  "permissions": [
    { "id": "ui.register", "reason": "在 PCL N 主导航中注册陶瓦联机页面。", "kind": "required" },
    { "id": "launch.observe", "reason": "关联正在运行的 Minecraft 游戏会话，并在游戏结束时清理联机。", "kind": "required" },
    { "id": "process.start", "reason": "启动随插件提供的陶瓦联机核心。", "kind": "required" },
    { "id": "process.input", "reason": "通过标准输入向陶瓦 Helper 传递一次性 IPC 鉴权密钥。", "kind": "required" },
    { "id": "process.terminate", "reason": "退出房间或停用插件时关闭陶瓦联机核心。", "kind": "required" },
    { "id": "pcl.network.limited", "reason": "建立 P2P、NAT 穿透和中继连接。", "kind": "required" },
    { "id": "game.output.read", "reason": "在结构化 LAN 地址不可用时，从游戏输出识别局域网端口。", "kind": "optional" },
    { "id": "process.output", "reason": "读取联机核心输出以生成错误诊断。", "kind": "optional" },
    { "id": "clipboard.write", "reason": "复制房间码、连接地址和诊断报告。", "kind": "optional" },
    { "id": "ui.window-management", "reason": "打开独立网络诊断窗口。", "kind": "optional" },
    { "id": "secure-storage", "reason": "使用系统安全存储保存长期身份密钥。", "kind": "optional" },
    { "id": "ui.inject", "reason": "在启动页显示陶瓦联机快捷入口。", "kind": "optional" }
  ],
  "localization": {
    "defaultCulture": "zh-CN",
    "supportedCultures": ["zh-CN", "en-US"],
    "resourcePath": "locales/{culture}.json"
  },
  "ui": {
    "api": { "minimum": "0.1", "maximumExclusive": "1.0" },
    "avalonia": { "minimum": "12.0", "maximumExclusive": "13.0" },
    "targets": [
      {
        "target": "pcl.navigation.main",
        "surface": ">=1.0 <2.0",
        "access": ["register"],
        "operations": [
          {
            "id": "cn.pcln.terracotta.page-registration",
            "kind": "register",
            "required": true,
            "fallback": "fail-load"
          }
        ]
      },
      {
        "target": "pcl.page.launch",
        "surface": ">=3.0 <4.0",
        "access": ["inject"],
        "operations": [
          {
            "id": "cn.pcln.terracotta.launch-contribution",
            "kind": "inject",
            "slot": "primary-actions.after",
            "priority": 420,
            "required": false,
            "fallback": "disable-feature"
          }
        ]
      },
      {
        "target": "pcl.window.main",
        "surface": ">=1.0 <2.0",
        "access": ["window-management"],
        "operations": [
          {
            "id": "cn.pcln.terracotta.diagnostics-window-registration",
            "kind": "register",
            "required": false,
            "fallback": "disable-feature"
          }
        ]
      }
    ]
  },
  "signing": {
    "fingerprint": "5701218D69B531E1A7ED35BB6E31F5974A273AEE"
  },
  "categories": ["multiplayer", "network"],
  "tags": ["terracotta", "p2p", "easytier", "scaffolding"]
}
